COMPOSE_PROJECT_NAME=aos_saas

AOS_APP_IMAGE=aos-openhands
AOS_APP_TAG=dev

# Stable binary runtime mode
AOS_AGENT_IMAGE=aos-agent-server
AOS_AGENT_TAG=dev
AOS_AGENT_TARGET=binary
AOS_AGENT_DEV_SOURCE_VOLUME=
AOS_AGENT_DEV_SOURCE_PATH=/agent-source

# Source-synced runtime mode
# AOS_AGENT_IMAGE=aos-agent-server
# AOS_AGENT_TAG=source-dev
# AOS_AGENT_TARGET=source
# AOS_AGENT_DEV_SOURCE_VOLUME=aos_saas_agent_source
# AOS_AGENT_DEV_SOURCE_PATH=/agent-source
